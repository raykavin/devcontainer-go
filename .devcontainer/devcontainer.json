{
    "name": "My Application DevContainer (Golang)",
    "workspaceFolder": "/workspaces/app",
    "dockerComposeFile": [
        "docker-compose.dev.yml"
    ],
    "containerEnv": {
        "PROJECT_NAME": "my-application",
        "GIT_CONFIG_DEV_USERNAME": "your_user_name",
        "GIT_CONFIG_DEV_EMAIL": "your-email@example.com",
        "GIT_CONFIG_TOKEN": "your_git_token_here",
        "GIT_REPO_ADDRESS": "https: //github.com/raykavin/devcontainer-go.git",
        "GIT_INIT_DEFAULT_BRANCH": "feat/initial-setup",
        "FORGEJO_HOST": "",
        "FORGEJO_PORT": "",
        "TZ": "America/Belem"
    },
    "service": "golang",
    "remoteUser": "vscode",
    "postCreateCommand": "sh ./.devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.Go",
                "liuchao.go-struct-tag",
                "yokoe.vscode-postfix-go",
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-portuguese-brazilian",
                "redhat.vscode-yaml",
                "teddyandturtle.fish",
                "neonxp.gotools",
                "tooltitudeteam.tooltitude",
                "usernamehw.errorlens",
                "mhutchie.git-graph"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "fish",
                "go.toolsManagement.checkForUpdates": "local",
                "go.useLanguageServer": true
            }
        }
    }
}
